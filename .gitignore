# ── Python ──────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
*.pyd
*.egg-info/
*.egg
dist/
build/
.eggs/

# ── Virtual environments ─────────────────────────────────────────────────────
.venv/
venv/
env/
ENV/

# ── Tool caches ──────────────────────────────────────────────────────────────
.pytest_cache/
.mypy_cache/
.ruff_cache/
.ipynb_checkpoints/

# ── Environment / secrets ────────────────────────────────────────────────────
.env
.env.*
*.pem
*.key

# ── OS ───────────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db

# ── Data directories (sensitive — never commit recordings or labels) ─────────
data/raw/*
data/processed/*
data/labels/*
data/synthetic/*
!data/raw/.gitkeep
!data/processed/.gitkeep
!data/labels/.gitkeep
!data/synthetic/.gitkeep

# ── Experiment outputs (gitignored; track via config pointer or notebook) ────
experiments/*
!experiments/.gitkeep

# ── Binary / large-file patterns ─────────────────────────────────────────────
*.h5
*.hdf5
*.sgy
*.segy
*.tdms
*.npy
*.npz
*.pt
*.pth
*.ckpt
*.onnx
